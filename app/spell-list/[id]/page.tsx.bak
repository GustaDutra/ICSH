"use client"

import { useState } from "react"
import Link from "next/link"

/* ─────────────────────────────────────────────────────────────
   TYPE  (mirrors SpellPage.tsx)
───────────────────────────────────────────────────────────── */
type Spell = {
  id: string
  misterio: string | string[]
  nivel: number
  nome: string
  Tempo: string
  Alcance: string
  Componentes: string
  duracao: string
  descricao: string
  nivel_superior: string
  escola?: string
}

/* ─────────────────────────────────────────────────────────────
   SAMPLE DATA  (replace with: import spells from "@/spells/spells.json")
───────────────────────────────────────────────────────────── */
const SPELLS: Spell[] = [
  {
    id: "fogo-1-1",
    nome: "Bola de Fogo",
    nivel: 1,
    misterio: ["Fogo"],
    escola: "Evocação",
    Tempo: "1 ação",
    Alcance: "18 metros",
    Componentes: "V, S, M (uma bolinha de enxofre)",
    duracao: "Instantânea",
    descricao:
      "Uma esfera brilhante do tamanho de um punho sai do seu dedo apontado para um ponto que você escolhe dentro do alcance e então explode com um trovão grave em uma explosão de chamas.\n\nEspecifique um ponto dentro do alcance. Cada criatura em uma esfera de 6 metros de raio centrada naquele ponto deve fazer um teste de resistência de Destreza. Uma criatura sofre 8d6 de dano de fogo em caso de falha, ou metade desse dano em caso de sucesso.",
    nivel_superior:
      "Quando você conjura essa magia usando um espaço de magia de 4° nível ou superior, o dano aumenta em 1d6 para cada nível de espaço acima do 3°.",
  },
  {
    id: "astral-3-1",
    nome: "Âncora Astral",
    nivel: 3,
    misterio: ["Astral"],
    escola: "Abjuração",
    Tempo: "1 ação bônus",
    Alcance: "Toque",
    Componentes: "V, S",
    duracao: "8 horas",
    descricao:
      "Você toca uma criatura voluntária e fixa sua alma ao plano material, impedindo qualquer deslocamento astral involuntário.\n\nA criatura tocada tem resistência a dano psíquico e vantagem em testes de resistência contra efeitos que forçariam deslocamento planar. Criaturas sob este efeito não podem ser banidas ou teleportadas contra sua vontade.",
    nivel_superior:
      "Quando conjurado com um espaço de 5° nível ou superior, você pode tocar uma criatura adicional para cada nível acima do 4°.",
  },
  {
    id: "necro-3-1",
    nome: "Animar Mortos",
    nivel: 3,
    misterio: ["Necromancia"],
    escola: "Necromancia",
    Tempo: "1 minuto",
    Alcance: "3 metros",
    Componentes: "V, S, M (uma gota de sangue, um pedaço de carne podre e um grão de pó de osso)",
    duracao: "Instantânea",
    descricao:
      "Essa magia cria um servo não morto. Escolha uma pilha de ossos ou um cadáver de uma criatura de tamanho Médio ou Pequeno dentro do alcance.\n\nSua magia penetra no alvo e o levanta como morto-vivo. O alvo se torna um esqueleto se você escolher ossos ou um zumbi se você escolher um cadáver. Em cada um dos seus turnos, você pode usar uma ação bônus para dar ordens mentais a qualquer criatura que você criou com essa magia se a criatura estiver a 18 metros de você.",
    nivel_superior:
      "Quando você conjura essa magia usando um espaço de magia de 4° nível ou superior, você anima ou reassume o controle de duas criaturas mortas-vivas adicionais para cada nível de espaço acima do 3°.",
  },
]

/* ─────────────────────────────────────────────────────────────
   HELPERS
───────────────────────────────────────────────────────────── */
const ESCOLA_STYLE: Record<string, { bg: string; color: string }> = {
  Evocação:     { bg: "var(--destructive)", color: "var(--destructive-foreground)" },
  Abjuração:    { bg: "var(--info)",        color: "var(--info-foreground)" },
  Transmutação: { bg: "var(--warning)",     color: "var(--warning-foreground)" },
  Conjuração:   { bg: "var(--success)",     color: "var(--success-foreground)" },
  Ilusão:       { bg: "var(--muted)",       color: "var(--muted-foreground)" },
  Necromancia:  { bg: "var(--primary)",     color: "var(--primary-foreground)" },
  Adivinhação:  { bg: "var(--secondary)",   color: "var(--secondary-foreground)" },
  Encantamento: { bg: "oklch(65% 0.15 290)", color: "white" },
}

const MISTERIO_ICON: Record<string, string> = {
  Astral: "✦", Cronomancia: "⧗", Espaçomancia: "⬡", Gravitomancia: "◉",
  Runomancia: "ᚱ", "Elemental Geral": "⬙", Água: "◈", Fogo: "△",
  Terra: "⬛", Vento: "◌", Elétrico: "⚡", Som: "◎",
  Flora: "✿", Areia: "◇", Veneno: "☠", Metal: "⬟",
  Gelo: "❄", Cristal: "◆", Magma: "◱", Sombra: "◐",
  Luz: "✦", Advinhação: "◉", Encantamento: "✧", Étermancia: "○",
  Ilusão: "◑", Invocação: "⬡", Necromancia: "☽", Oniromancia: "◫",
  Transmutação: "⬠", Umbramancia: "●",
}

function nivelLabel(n: number) {
  if (n === 0) return "Truque"
  const suffix = ["°","°","°","°","°","°","°","°","°","°"][n - 1] ?? "°"
  return `${n}${suffix} Nível`
}

function getMisterios(m: string | string[]): string[] {
  if (Array.isArray(m)) return m
  return m.split(",").map((s) => s.trim())
}

/* ─────────────────────────────────────────────────────────────
   META CARD
───────────────────────────────────────────────────────────── */
function MetaCard({ icon, label, value }: { icon: React.ReactNode; label: string; value: string }) {
  return (
    <div style={{
      background: "var(--card)",
      border: "1px solid var(--border)",
      borderRadius: "var(--radius)",
      padding: "0.875rem 1rem",
      display: "flex",
      alignItems: "flex-start",
      gap: "0.75rem",
      boxShadow: "var(--shadow-xs)",
    }}>
      <span style={{ fontSize: "1rem", lineHeight: 1, marginTop: "0.125rem", flexShrink: 0, color: "var(--muted-foreground)" }}>
        {icon}
      </span>
      <div style={{ minWidth: 0 }}>
        <p style={{ fontSize: "0.6875rem", fontWeight: 700, letterSpacing: "0.06em", textTransform: "uppercase", color: "var(--muted-foreground)", margin: "0 0 0.25rem" }}>
          {label}
        </p>
        <p style={{ fontSize: "0.9rem", fontWeight: 600, margin: 0, lineHeight: 1.3, wordBreak: "break-word" }}>
          {value}
        </p>
      </div>
    </div>
  )
}

/* ─────────────────────────────────────────────────────────────
   NOT FOUND
───────────────────────────────────────────────────────────── */
function NotFound() {
  return (
    <div style={{ minHeight: "100vh", background: "var(--background)", display: "flex", alignItems: "center", justifyContent: "center", fontFamily: "'Plus Jakarta Sans', system-ui, sans-serif" }}>
      <div style={{ textAlign: "center", padding: "2rem" }}>
        <div style={{ fontSize: "3rem", marginBottom: "1rem" }}>☽</div>
        <h1 style={{ fontSize: "1.5rem", fontWeight: 800, letterSpacing: "-0.03em", marginBottom: "0.5rem" }}>
          Magia não encontrada
        </h1>
        <p style={{ color: "var(--muted-foreground)", marginBottom: "1.5rem", fontSize: "0.9375rem" }}>
          Esta magia não existe no grimório.
        </p>
        <Link
          href="/spell-list"
          style={{
            padding: "0.5rem 1.25rem",
            background: "var(--primary)", color: "var(--primary-foreground)",
            borderRadius: "var(--radius-pill)", textDecoration: "none",
            fontSize: "0.875rem", fontWeight: 700,
          }}
        >
          ← Voltar ao Grimório
        </Link>
      </div>
    </div>
  )
}

/* ─────────────────────────────────────────────────────────────
   SPELL PAGE  (receives id prop — in Next.js App Router use params)
───────────────────────────────────────────────────────────── */
export default function SpellPage({ params }: { params: { id: string } }) {
  /* In production: const spell = spells.find(s => String(s.id) === String(params.id)) */
  const spell: Spell | undefined = SPELLS.find((s) => String(s.id) === String(params?.id)) ?? SPELLS[0]
  const [dark, setDark] = useState(false)

  if (!spell) return <NotFound />

  const misterios = getMisterios(spell.misterio)
  const escolaStyle = spell.escola ? (ESCOLA_STYLE[spell.escola] ?? { bg: "var(--muted)", color: "var(--muted-foreground)" }) : null
  const hasNivelSuperior = spell.nivel_superior && spell.nivel_superior.trim().length > 0

  return (
    <div
      className={dark ? "dark" : ""}
      style={{
        background: "var(--background)", color: "var(--foreground)", minHeight: "100vh",
        fontFamily: "'Plus Jakarta Sans', system-ui, sans-serif",
        transition: "background 0.3s, color 0.3s",
      }}
    >
      {/* ── HEADER ── */}
      <header style={{
        position: "sticky", top: 0, zIndex: 40,
        background: "var(--card)", borderBottom: "1px solid var(--border)",
        padding: "0.875rem 2rem",
        display: "flex", alignItems: "center", justifyContent: "space-between", gap: "1rem",
        transition: "background 0.3s",
      }}>
        {/* Back link */}
        <Link
          href="/spell-list"
          style={{
            display: "flex", alignItems: "center", gap: "0.5rem",
            fontSize: "0.875rem", fontWeight: 600, color: "var(--muted-foreground)",
            textDecoration: "none", transition: "color 0.15s",
          }}
          onMouseEnter={(e) => (e.currentTarget.style.color = "var(--foreground)")}
          onMouseLeave={(e) => (e.currentTarget.style.color = "var(--muted-foreground)")}
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Grimório
        </Link>

        {/* Logo */}
        <div style={{ display: "flex", alignItems: "center", gap: "0.625rem" }}>
          <div style={{ width: 28, height: 28, background: "var(--primary)", borderRadius: "var(--radius-sm)", display: "flex", alignItems: "center", justifyContent: "center", transition: "background 0.3s" }}>
            <span style={{ color: "var(--primary-foreground)", fontSize: "0.9rem" }}>✦</span>
          </div>
          <span style={{ fontSize: "0.9375rem", fontWeight: 800, letterSpacing: "-0.02em" }}>Arcano</span>
        </div>

        {/* Dark mode */}
        <button
          onClick={() => setDark(!dark)}
          style={{
            padding: "0.4rem 0.875rem", borderRadius: "var(--radius-pill)",
            border: "1.5px solid var(--border)", background: "transparent",
            color: "var(--foreground)", fontSize: "0.875rem", fontWeight: 600,
            cursor: "pointer", fontFamily: "inherit",
          }}
        >
          {dark ? "☀" : "☾"}
        </button>
      </header>

      {/* ── HERO BAND ── */}
      <div style={{
        background: "var(--primary)", color: "var(--primary-foreground)",
        padding: "2.5rem 2rem 2rem",
        transition: "background 0.3s",
      }}>
        <div style={{ maxWidth: 720, margin: "0 auto" }}>

          {/* Misterio badges */}
          <div style={{ display: "flex", flexWrap: "wrap", gap: "0.5rem", marginBottom: "1rem" }}>
            {misterios.map((m) => (
              <span
                key={m}
                style={{
                  display: "inline-flex", alignItems: "center", gap: "0.375rem",
                  padding: "0.25rem 0.75rem",
                  background: "oklch(25% 0 0)", color: "oklch(85% 0 0)",
                  borderRadius: "var(--radius-pill)",
                  fontSize: "0.75rem", fontWeight: 700, letterSpacing: "0.04em",
                }}
              >
                <span style={{ fontFamily: "monospace" }}>{MISTERIO_ICON[m] ?? "◈"}</span>
                {m}
              </span>
            ))}
            {/* Escola badge */}
            {spell.escola && escolaStyle && (
              <span style={{
                padding: "0.25rem 0.75rem",
                background: "oklch(30% 0 0)", color: "oklch(80% 0 0)",
                borderRadius: "var(--radius-pill)",
                fontSize: "0.75rem", fontWeight: 700, letterSpacing: "0.04em",
              }}>
                {spell.escola}
              </span>
            )}
          </div>

          {/* Spell name */}
          <h1 style={{
            fontSize: "clamp(1.75rem, 5vw, 2.75rem)",
            fontWeight: 800, letterSpacing: "-0.04em",
            margin: "0 0 0.625rem", lineHeight: 1.05,
            color: "var(--primary-foreground)",
          }}>
            {spell.nome}
          </h1>

          {/* Level pill */}
          <div style={{ display: "inline-flex", alignItems: "center", gap: "0.625rem" }}>
            <span style={{
              display: "inline-flex", alignItems: "center",
              padding: "0.375rem 0.875rem",
              background: "oklch(22% 0 0)", color: "oklch(90% 0 0)",
              borderRadius: "var(--radius-pill)",
              fontSize: "0.8125rem", fontWeight: 700, letterSpacing: "0.02em",
            }}>
              {nivelLabel(spell.nivel)}
            </span>
          </div>
        </div>
      </div>

      {/* ── CONTENT ── */}
      <div style={{ maxWidth: 720, margin: "0 auto", padding: "2rem 1.5rem 4rem" }}>

        {/* Meta grid */}
        <div style={{
          display: "grid",
          gridTemplateColumns: "repeat(auto-fill, minmax(160px, 1fr))",
          gap: "0.75rem",
          marginBottom: "2.5rem",
        }}>
          <MetaCard icon="⚡" label="Tempo de Conjuração" value={spell.Tempo} />
          <MetaCard icon="◎" label="Alcance" value={spell.Alcance} />
          <MetaCard icon="⬡" label="Componentes" value={spell.Componentes} />
          <MetaCard icon="⧗" label="Duração" value={spell.duracao} />
        </div>

        {/* Description */}
        <div style={{ marginBottom: "2rem" }}>
          <h2 style={{
            fontSize: "0.6875rem", fontWeight: 700, letterSpacing: "0.1em",
            textTransform: "uppercase", color: "var(--muted-foreground)",
            marginBottom: "1rem", paddingBottom: "0.625rem",
            borderBottom: "1px solid var(--border)",
          }}>
            Descrição
          </h2>
          <div style={{
            fontSize: "0.9375rem", lineHeight: 1.8, color: "var(--foreground)",
            whiteSpace: "pre-line",
          }}>
            {spell.descricao}
          </div>
        </div>

        {/* Nivel superior */}
        {hasNivelSuperior && (
          <div style={{
            background: "var(--card)",
            border: "1px solid var(--border)",
            borderRadius: "var(--radius-lg)",
            padding: "1.25rem 1.5rem",
            boxShadow: "var(--shadow-sm)",
          }}>
            {/* Header row */}
            <div style={{ display: "flex", alignItems: "center", gap: "0.625rem", marginBottom: "0.875rem" }}>
              <div style={{
                width: 28, height: 28, background: "var(--primary)", color: "var(--primary-foreground)",
                borderRadius: "var(--radius-sm)", display: "flex", alignItems: "center", justifyContent: "center",
                fontSize: "0.75rem", fontWeight: 800, flexShrink: 0, transition: "background 0.3s",
              }}>
                ↑
              </div>
              <h3 style={{
                fontSize: "0.8125rem", fontWeight: 700, letterSpacing: "0.04em",
                textTransform: "uppercase", color: "var(--foreground)", margin: 0,
              }}>
                Em Níveis Superiores
              </h3>
            </div>
            <p style={{ fontSize: "0.9375rem", lineHeight: 1.7, color: "var(--muted-foreground)", margin: 0, whiteSpace: "pre-line" }}>
              {spell.nivel_superior}
            </p>
          </div>
        )}

        {/* Navigation footer */}
        <div style={{
          marginTop: "3rem", paddingTop: "1.5rem",
          borderTop: "1px solid var(--border)",
          display: "flex", alignItems: "center", justifyContent: "space-between",
          flexWrap: "wrap", gap: "1rem",
        }}>
          <Link
            href="/spell-list"
            style={{
              display: "inline-flex", alignItems: "center", gap: "0.5rem",
              padding: "0.625rem 1.25rem",
              background: "transparent", color: "var(--foreground)",
              border: "1.5px solid var(--border)", borderRadius: "var(--radius-pill)",
              fontSize: "0.875rem", fontWeight: 600, textDecoration: "none",
              transition: "background 0.15s",
            }}
            onMouseEnter={(e) => (e.currentTarget.style.background = "var(--muted)")}
            onMouseLeave={(e) => (e.currentTarget.style.background = "transparent")}
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5">
              <polyline points="15 18 9 12 15 6" />
            </svg>
            Todos os Mistérios
          </Link>

          <div style={{ display: "flex", alignItems: "center", gap: "0.5rem" }}>
            {misterios.map((m) => (
              <span
                key={m}
                style={{
                  padding: "0.375rem 0.875rem",
                  background: "var(--muted)", color: "var(--muted-foreground)",
                  borderRadius: "var(--radius-pill)",
                  fontSize: "0.75rem", fontWeight: 700,
                  display: "inline-flex", alignItems: "center", gap: "0.375rem",
                }}
              >
                <span style={{ fontFamily: "monospace" }}>{MISTERIO_ICON[m] ?? "◈"}</span>
                {m}
              </span>
            ))}
          </div>
        </div>

      </div>
    </div>
  )
}
